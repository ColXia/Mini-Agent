# QQ Bot Channel Configuration

# QQ Bot credentials
QQBOT_APPID=your_appid_here
QQBOT_SECRET=your_secret_here
QQBOT_SANDBOX=true
QQBOT_MODE=websocket

# Event intents
QQBOT_INTENTS=GUILD_MESSAGES,DIRECT_MESSAGE,GROUP_AT_MESSAGE_CREATE,C2C_MESSAGE_CREATE,PUBLIC_GUILD_MESSAGES

# Webhook mode settings (optional)
QQBOT_WEBHOOK_PATH=/qqbot/webhook
QQBOT_PORT=3520

# Mini-Agent Gateway
MINI_AGENT_GATEWAY_BASE=http://127.0.0.1:8008
QQBOT_GATEWAY_AUTH_TOKEN=
QQBOT_DEFAULT_WORKSPACE=./workspace
QQBOT_DEFAULT_DRY_RUN=false
QQBOT_SESSION_STORE_PATH=.qqbot_sessions.json
QQBOT_ALLOWED_WORKSPACE_ROOTS=./workspace
QQBOT_MAX_MESSAGE_CHARS=12000
QQBOT_MAX_REPLY_CHUNK_SIZE=1400
