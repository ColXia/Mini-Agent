# WeChat webhook settings
WECHAT_TOKEN=your_wechat_token
WECHAT_APPID=
WECHAT_HOST=0.0.0.0
WECHAT_PORT=3530
WECHAT_PATH=/wechat/webhook

# Mini-Agent Gateway
MINI_AGENT_GATEWAY_BASE=http://127.0.0.1:8008
WECHAT_GATEWAY_AUTH_TOKEN=
WECHAT_DEFAULT_WORKSPACE=./workspace
WECHAT_DEFAULT_DRY_RUN=false
WECHAT_SESSION_STORE_PATH=.wechat_sessions.json
WECHAT_ALLOWED_WORKSPACE_ROOTS=./workspace
WECHAT_MAX_MESSAGE_CHARS=12000
WECHAT_MAX_RESPONSE_CHARS=4000
WECHAT_MAX_BODY_BYTES=1048576
WECHAT_MAX_TIMESTAMP_SKEW_SECONDS=600
WECHAT_DEDUPE_WINDOW_SIZE=4000
