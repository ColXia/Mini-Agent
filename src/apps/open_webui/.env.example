# Mini-Agent Gateway endpoint used by Open WebUI adapter
MINI_AGENT_GATEWAY_URL=http://host.docker.internal:8008

# Optional: set when gateway auth token is enabled
MINI_AGENT_GATEWAY_AUTH_TOKEN=

# Adapter token(s) accepted by /v1 endpoints (comma-separated)
MINI_AGENT_OPENWEBUI_API_KEYS=mini-agent-openwebui-token

# Open WebUI uses one primary OpenAI API key
# Keep this key included in MINI_AGENT_OPENWEBUI_API_KEYS
MINI_AGENT_OPENWEBUI_PRIMARY_API_KEY=mini-agent-openwebui-token

# Exposed model list
MINI_AGENT_OPENWEBUI_DEFAULT_MODEL=mini-agent
MINI_AGENT_OPENWEBUI_MODELS=mini-agent

# Adapter runtime settings
MINI_AGENT_OPENWEBUI_TIMEOUT_SECONDS=30
MINI_AGENT_OPENWEBUI_CHANNEL_TYPE=open_webui
