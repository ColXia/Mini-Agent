# Local development preset key template.
# This file is NOT read by the program.
# Copy needed values to .env.local (loaded after system environment variables).

# --- Official Provider API Keys ---
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# --- MiniMax Provider ---
MINIMAX_API_KEY=YOUR_MINIMAX_API_KEY_HERE
MINIMAX_API_HOST=https://api.minimaxi.com

# --- MaaS Provider (optional) ---
# MAAS_API_KEY=YOUR_MAAS_API_KEY_HERE
# MAAS_API_HOST=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2
